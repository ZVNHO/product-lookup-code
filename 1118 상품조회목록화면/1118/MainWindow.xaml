<Window x:Class="_1118.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1118"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <TabControl Margin="0,0,0,-44">
            <!-- 상품 등록 탭 -->
            <TabItem Header="상품 등록">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Text="상품 등록" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                        <!-- 상품명 -->
                        <TextBlock Text="상품명:" Margin="0,5"/>
                        <TextBox x:Name="ProductNameInput" Width="300" Height="30" Margin="0,0,0,10"/>

                        <!-- 가격 -->
                        <TextBlock Text="가격:" Margin="0,5"/>
                        <TextBox x:Name="ProductPriceInput" Width="300" Height="30" Margin="0,0,0,10"/>

                        <!-- 카테고리 -->
                        <TextBlock Text="카테고리:" Margin="0,5"/>
                        <ComboBox x:Name="ProductCategoryInput" Width="300" Height="30" Margin="0,0,0,10">
                            <ComboBoxItem Content="전자제품"/>
                            <ComboBoxItem Content="스포츠/레저"/>
                            <ComboBoxItem Content="도서"/>
                            <ComboBoxItem Content="가구"/>
                            <ComboBoxItem Content="옷"/>
                            <ComboBoxItem Content="기타"/>
                        </ComboBox>

                        <!-- 설명 -->
                        <TextBlock Text="설명:" Margin="0,5"/>
                        <TextBox x:Name="ProductDescriptionInput" Width="300" Height="100" Margin="0,0,0,10" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <!-- 등록 버튼 -->
                        <Button Content="등록" Width="100" Height="30" Click="RegisterButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 상품 조회 탭 -->
            <TabItem Header="상품 조회">
                <Grid Margin="10">
                    <ListView x:Name="ProductListView" Margin="0,10,0,10" SelectionChanged="ProductListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="상품명" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="가격" Width="100" DisplayMemberBinding="{Binding Price}"/>
                                <GridViewColumn Header="카테고리" Width="150" DisplayMemberBinding="{Binding Category}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- 상세 정보 -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Width="200" Margin="10">
                        <TextBlock Text="상세 정보" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
                        <TextBlock x:Name="DetailName" Text="상품명: " Margin="0,10,0,0"/>
                        <TextBlock x:Name="DetailPrice" Text="가격: " Margin="0,10,0,0"/>
                        <TextBlock x:Name="DetailCategory" Text="카테고리: " Margin="0,10,0,0"/>
                        <TextBlock x:Name="DetailDescription" Text="설명: " Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>